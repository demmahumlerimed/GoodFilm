# GoodFilm — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's already in .gitignore

# ── TMDB (The Movie Database) ──────────────────────────
# Get your key at: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=2abbda52b30975da8104f64238c074ad
VITE_TMDB_BEARER=

# ── OMDB (Open Movie Database) ─────────────────────────
# Get your free key at: https://www.omdbapi.com/apikey.aspx
VITE_OMDB_API_KEY=http://www.omdbapi.com/?i=tt3896198&apikey=ee840519

# ── Supabase (Cloud Sync) ──────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
# The anon key MUST be a JWT starting with eyJ...
VITE_SUPABASE_URL=https://pdjgsxbvrjiswxpztjxa.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_F4qGznnYVhpSLZr6kNGilw_1BDgYgYb
